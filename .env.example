# Copy to .env.local and fill in. Never commit real secrets.

# --- X (Twitter) OAuth 2.0 app credentials (developer portal) ---
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Auth.js ---
AUTH_SECRET=            # generate with: npx auth secret
AUTH_URL=http://localhost:3000   # in prod: https://your-app.vercel.app

# --- Database (SQLite local; Postgres in prod) ---
DATABASE_URL="file:./dev.db"

# --- App config ---
ADMIN_USERNAMES=        # comma-separated X handles (no @) granted ADMIN
SITE_PASSWORD=          # shared password gating the whole portal
