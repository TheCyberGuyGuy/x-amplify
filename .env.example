# Copy to .env.local and fill in. Never commit real secrets.

# --- X (Twitter) OAuth 2.0 app credentials (developer portal) ---
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# --- Auth.js ---
AUTH_SECRET=            # generate with: npx auth secret
AUTH_URL=http://localhost:3000   # in prod: https://your-app.vercel.app

# --- Database (SQLite local; Postgres in prod) ---
DATABASE_URL="file:./dev.db"

# --- Post polling / push notifications ---
X_BEARER_TOKEN=         # app-only bearer token (X developer portal) for search/recent
CRON_SECRET=            # random string; Vercel Cron sends it as Authorization: Bearer
PUSH_MONTHLY_READ_BUDGET=2000   # hard cap on X post-reads per month (~$10 at $0.005/read)
PUSH_ACTIVE_HOURS=07-23 # polling window (local hours, supports e.g. 22-06); empty = 24/7
PUSH_TZ=Asia/Jerusalem  # timezone for PUSH_ACTIVE_HOURS
PUSH_DAILY_CAP=3        # max pushes per user per day (fatigue guard)

# --- Web push (VAPID; generate with: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@etoro.com

# --- App config ---
SUPER_ADMIN_USERNAMES=  # comma-separated X handles (no @); can promote admins
ADMIN_USERNAMES=        # bootstrap admins (super admins can promote more in-app)
SITE_PASSWORD=          # shared password gating the whole portal
