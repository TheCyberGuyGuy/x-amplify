// eToro X-Amplify — data model
// Auth.js (User/Account/Session/VerificationToken) + app models (PoolHandle/FollowEvent)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // X-specific
  xUserId       String?   @unique
  username      String?
  role          String    @default("EMPLOYEE") // EMPLOYEE | ADMIN
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  addedHandles PoolHandle[]  @relation("AddedBy")
  followEvents FollowEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PoolHandle {
  id              String   @id @default(cuid())
  username        String   @unique // lowercase, no @
  xUserId         String?
  // ETORIAN | POPULAR_INVESTOR | ETORO_HANDLE. null = self-registered, pending onboarding choice.
  type            String?
  displayName     String?
  profileImage    String?
  description     String?
  isEtoroVerified Boolean  @default(false)
  active          Boolean  @default(true)
  addedById       String?
  addedBy         User?    @relation("AddedBy", fields: [addedById], references: [id])
  createdAt       DateTime @default(now())

  followEvents FollowEvent[]
}

model FollowEvent {
  id           String     @id @default(cuid())
  userId       String
  poolHandleId String
  clickedAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolHandle   PoolHandle @relation(fields: [poolHandleId], references: [id], onDelete: Cascade)

  @@unique([userId, poolHandleId])
}
