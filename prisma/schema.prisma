// eToro X-Amplify — data model
// Auth.js (User/Account/Session/VerificationToken) + app models (PoolHandle/FollowEvent)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // X-specific
  xUserId       String?   @unique
  username      String?
  role          String    @default("EMPLOYEE") // EMPLOYEE | ADMIN
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  addedHandles      PoolHandle[]       @relation("AddedBy")
  followEvents      FollowEvent[]
  followStates      FollowState[]
  pushSubscriptions PushSubscription[]
  notifications     NotificationLog[]
  engagements       EngagementEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PoolHandle {
  id              String   @id @default(cuid())
  username        String   @unique // lowercase, no @
  xUserId         String?
  // ETORIAN | POPULAR_INVESTOR | ETORO_HANDLE. null = self-registered, pending onboarding choice.
  type            String?
  displayName     String?
  profileImage    String?
  description     String?
  isEtoroVerified Boolean  @default(false)
  active          Boolean  @default(true)
  addedById       String?
  addedBy         User?    @relation("AddedBy", fields: [addedById], references: [id])
  createdAt       DateTime @default(now())
  // Cached latest original post (shared across all viewers; refreshed on a TTL).
  latestTweetId   String?
  latestTweetAt   DateTime?
  tweetsCheckedAt DateTime?
  // Opt-in per handle: only flagged handles trigger browser push notifications.
  pushEnabled     Boolean  @default(false)

  followEvents FollowEvent[]
  followStates FollowState[]
  posts        Post[]
}

// A post discovered by the cron poll. tweetId uniqueness is the dedupe anchor:
// polls overlap their time windows on purpose, so re-seen tweets are no-ops.
model Post {
  id           String     @id @default(cuid())
  tweetId      String     @unique
  poolHandleId String
  text         String? // truncated preview, used for notification bodies
  postedAt     DateTime
  discoveredAt DateTime   @default(now())
  notifiedAt   DateTime? // null = no push sent (yet) for this post
  poolHandle   PoolHandle @relation(fields: [poolHandleId], references: [id], onDelete: Cascade)

  notifications NotificationLog[]
  engagements   EngagementEvent[]

  @@index([poolHandleId, postedAt])
}

// One row per browser/device that opted into push. endpoint is the push
// service's unique URL for that device; a 404/410 on send means the
// subscription is dead and the row gets deleted.
model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One row per (user, post) push actually sent. The unique constraint makes
// double-sends structurally impossible; the daily cap counts recent rows.
model NotificationLog {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  sentAt    DateTime  @default(now())
  clickedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, sentAt])
}

// A boost click (like/repost/quote intent) on a discovered post.
// Generalizes FollowEvent; the actual action happens on X via intent links.
model EngagementEvent {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  action    String // LIKE | REPOST | QUOTE
  clickedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, action])
}

// Audit log of cron polls. postsRead sums to the month's X read spend
// (pay-per-read pricing), which the poller checks against a hard budget.
model PollRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  requestCount Int       @default(0)
  postsRead    Int       @default(0)
  newPosts     Int       @default(0)
  status       String // RUNNING | SUCCESS | ERROR
  error        String?

  @@index([startedAt])
}

// Snapshot of whether a logged-in user follows a pool handle, captured on
// each dashboard load. Powers the network leaderboard (we can only know a
// person's follow state while they themselves are authenticated).
model FollowState {
  id           String     @id @default(cuid())
  userId       String
  poolHandleId String
  following    Boolean
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolHandle   PoolHandle @relation(fields: [poolHandleId], references: [id], onDelete: Cascade)

  @@unique([userId, poolHandleId])
}

model FollowEvent {
  id           String     @id @default(cuid())
  userId       String
  poolHandleId String
  clickedAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  poolHandle   PoolHandle @relation(fields: [poolHandleId], references: [id], onDelete: Cascade)

  @@unique([userId, poolHandleId])
}
